{
  "name": "BatterySimPiece",
  "description": "Simulates battery charge/discharge, self-consumption, peak-shaving",
  "version": "1.0.0",
  "inputs": [
    {"name": "net_load_csv", "type": "file", "description": "15-min net load after solar (kW)"},
    {"name": "battery_config_yml", "type": "file", "description": "Battery specs & strategy"},
    {"name": "scenario_yml", "type": "file", "description": "Scenario definition (peak hours, etc.)"}
  ],
  "outputs": [
    {"name": "virtual_battery_soc_csv", "type": "file", "description": "15-min SOC (%)"},
    {"name": "battery_summary_csv", "type": "file", "description": "Cycles, peak-shaved energy, etc."}
  ]
}