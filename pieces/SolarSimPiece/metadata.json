{
  "name": "SolarSimPiece",
  "description": "Generates synthetic solar PV profile using pvlib and weather data",
  "version": "1.0.0",
  "inputs": [
    {"name": "weather_csv", "type": "file", "description": "Weather CSV with irradiance & temp"},
    {"name": "solar_config_yml", "type": "file", "description": "PV configuration (capacity, tilt, etc.)"}
  ],
  "outputs": [
    {"name": "virtual_solar_csv", "type": "file", "description": "15-min solar generation (kW)"}
  ]
}